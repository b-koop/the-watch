{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vitest"
    ],
    "lib": [
      "ES2022",
      "DOM"
    ],
    "allowImportingTsExtensions": true
  },
  "include": [
    "extensions/**/*.ts",
    "test/**/*.ts",
    "vitest.config.ts"
  ]
}
